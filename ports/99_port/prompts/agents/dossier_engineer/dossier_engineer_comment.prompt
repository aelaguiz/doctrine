import .shared


output DossierEngineerHandoff: "Dossier Engineer Handoff"
    target: common.handoffs.shared.IssueComment
        issue: "CURRENT_ISSUE"
    shape: common.handoffs.shared.HandoffCommentText
    requirement: Required

    must_include: "Must Include"
        what_changed: "What Changed"
            "Say what this turn changed."

        decisions_now_locked: "Decisions Now Locked"
            "Say which dossier decisions are now locked."

        use_now: "Use Now"
            "Name the exact current dossier files the next owner should trust now."

        failing_gate_if_blocked: "Failing Gate If Blocked"
            "If the work is blocked, name the exact failing gate. Otherwise say plainly that no blocking gate applies."

        next_owner: "Next Owner"
            "Name the honest next owner when ownership is changing now."

        current_packet: "Current Packet"
            "Name the exact dossier packet being handed off."

        review_files: "Review Files"
            "Name the current review files explicitly, or say plainly that no current review files apply yet."

        proof_location: "Proof Location"
            "Say whether proof is inline in the dossier or lives in named support files."

    standalone_read: "Standalone Read"
        "A downstream reader should be able to read this comment alone and understand what changed, which dossier packet and files are current now, whether review files apply, where proof lives, and who owns next."
