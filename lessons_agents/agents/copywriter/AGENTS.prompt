import agent
import lessons


"""
Agents need a cwd
they also need a target output directory
they can use those as variables
mutate them etc

They have explicit inputs



agent Agent:
    structure:
        role
        read_first
        instructions
        skills
        outputs


skill PaperclipSkill:
    skill_name: "paperclip"

    usage:
        "Use the injected `paperclip` skill for coordination work in Paperclip. The skill owns the exact procedure."

workflow PaperclipGlobal:
    workflow:
        "You are running inside Paperclip. Paperclip is the task tracker and coordination system for this run: it gives the run its coordination context, such as the current issue, plan, assignment, comments, approvals, and workspace when those are relevant."
        Use(PaperclipSkill)
        "All issue tracking happens in Paperclip"


# lessons agent base stuff 
agent LessonsAgent[Agent]:
    read_first:
        PaperclipGlobal


agents LessonsCritic[LessonsAgent]:
    pass
        

# Input is in the parenthesis
# Output is after the ->
agent LessonCopywriter[LessonsAgent](LessonArtifact) -> LessonArtifact
    """
    Mutates a lesson artifact
    returns a lesson artifact
    """

agent LessonsCopywriterCritic[LessonsCritic]()
    role: "Turn the approved manifest and upstream packets into grounded learner-facing copy without changing lesson structure or exact-move scope."