{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PyPrompt",
  "scopeName": "source.pyprompt",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#import"
    },
    {
      "include": "#workflow"
    },
    {
      "include": "#inputSource"
    },
    {
      "include": "#input"
    },
    {
      "include": "#outputTarget"
    },
    {
      "include": "#outputShape"
    },
    {
      "include": "#output"
    },
    {
      "include": "#jsonSchema"
    },
    {
      "include": "#skill"
