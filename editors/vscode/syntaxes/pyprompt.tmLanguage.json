  "repository": {
    "comments": {
      "name": "comment.line.number-sign.pyprompt",
      "match": "^\\s*#.*$"
    },
    "strings": {
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.pyprompt"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.pyprompt"
        }
      },
      "contentName": "string.quoted.double.pyprompt",
      "patterns": [
        {
          "include": "#stringInterpolation"
        }
      ]
    },
    "stringInterpolation": {
      "match": "(\\{\\{)\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*))?\\s*(\\}\\})",
      "captures": {
        "1": {
          "name": "punctuation.definition.interpolation.begin.pyprompt"
        },
        "2": {
          "name": "support.type.reference.pyprompt"
        },
        "3": {
          "name": "punctuation.separator.interpolation.pyprompt"
        },
        "4": {
          "name": "variable.other.member.pyprompt"
        },
        "5": {
          "name": "punctuation.definition.interpolation.end.pyprompt"
        }
      }
    },
    "import": {
      "match": "^(\\s*)(import)(\\s+)((?:\\.+)?[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*$",
      "captures": {
        "2": {
          "name": "keyword.declaration.pyprompt"
        },
        "4": {
          "name": "support.type.reference.pyprompt"
        }
      }
    },
    "workflow": {
      "match": "^(\\s*)(workflow)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(?:\\s*(\\[)([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(\\]))?(\\s*)(:)",
      "captures": {
        "2": {
          "name": "keyword.declaration.pyprompt"
        },
        "4": {
          "name": "entity.name.type.pyprompt"
        },
        "5": {
          "name": "punctuation.section.inheritance.begin.pyprompt"
        },
        "6": {
          "name": "entity.other.inherited-class.pyprompt"
        },
        "7": {
          "name": "punctuation.section.inheritance.end.pyprompt"
        },
        "9": {
          "name": "punctuation.separator.key-value.pyprompt"
        }
      }
    },
    "inputSource": {
      "match": "^(\\s*)(input)(\\s+)(source)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(:)",
      "captures": {
        "2": {
          "name": "keyword.declaration.pyprompt"
        },
        "4": {
          "name": "keyword.declaration.pyprompt"
        },
        "6": {
