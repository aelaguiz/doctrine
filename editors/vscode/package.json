{
  "name": "doctrine-language",
  "displayName": "Doctrine Language Support",
  "description": "Local VS Code syntax highlighting and editor behavior for Doctrine prompt files.",
  "version": "0.0.0",
  "publisher": "aelaguiz",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aelaguiz/doctrine.git"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:doctrine"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:snap && npm run test:integration",
    "test:unit": "vscode-tmgrammar-test --config ./package.json \"tests/unit/**/*.test.prompt\"",
    "test:snap": "vscode-tmgrammar-snap --config ./package.json \"tests/snap/examples/**/*.prompt\"",
    "test:snap:update": "vscode-tmgrammar-snap --updateSnapshot --config ./package.json \"tests/snap/examples/**/*.prompt\"",
    "test:integration": "node ./tests/integration/run.js",
    "package:vsix": "npm test && uv run --locked python scripts/validate_lark_alignment.py && uv run --locked python scripts/package_vsix.py && uv run --locked python scripts/run_packaged_vsix_smoke.py"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "3.7.1",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "doctrine",
        "extensions": [
          ".prompt"
        ],
        "aliases": [
          "Doctrine",
          "doctrine"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "doctrine",
        "scopeName": "source.doctrine",
        "path": "./syntaxes/doctrine.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "@iarna/toml": "2.2.5"
  }
}
