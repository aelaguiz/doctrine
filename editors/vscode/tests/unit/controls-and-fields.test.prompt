# SYNTAX TEST "source.pyprompt" "controls, fields, keys, and routes"

    role: "Role"
#   ^^^^ keyword.other.field.pyprompt
#       ^ punctuation.separator.key-value.pyprompt

        use opening: shared.workflow.Opening
#       ^^^ keyword.control.pyprompt
#           ^ entity.name.section.pyprompt
#                  ^ punctuation.separator.key-value.pyprompt
#                    ^ entity.name.type.reference.use-target.pyprompt

        inherit preparation
#       ^^^^^^^ keyword.control.pyprompt
#               ^ support.type.reference.pyprompt

        abstract workflow_core
#       ^^^^^^^^ keyword.control.pyprompt
#                ^ support.type.reference.pyprompt

        override delivery: RevisedDelivery
#       ^^^^^^^^ keyword.control.pyprompt
#                ^ entity.name.section.pyprompt
#                        ^ punctuation.separator.key-value.pyprompt
#                          ^ entity.name.type.reference.override.pyprompt

            route "If accepted" -> ProjectLead
#           ^^^^^ keyword.control.pyprompt
#                                ^ keyword.operator.route.pyprompt
#                                ^ keyword.operator.pyprompt
#                                ^ punctuation.separator.route.pyprompt
#                                   ^ entity.name.type.reference.route-target.pyprompt

    your_job: roles.project_lead.ProjectLeadJob
#   ^^^^^^^^ entity.name.section.pyprompt
#           ^ punctuation.separator.key-value.pyprompt
#             ^ entity.name.type.reference.key-value.pyprompt

        produced_output: "Produced Output"
#       ^ entity.name.section.pyprompt
#                      ^ punctuation.separator.key-value.pyprompt
#                        ^ string.quoted.double.pyprompt

        CurrentIssue
#       ^^^^^^^^^^^^ entity.name.type.reference.standalone.pyprompt

        shared.contracts.TrackMetadata
#       ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ entity.name.type.reference.standalone.pyprompt

        ProjectLead
