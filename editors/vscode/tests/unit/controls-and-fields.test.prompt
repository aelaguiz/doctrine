# SYNTAX TEST "source.doctrine" "controls, fields, keys, and routes"

    role: "Role"
#   ^^^^ keyword.other.field.doctrine
#       ^ punctuation.separator.key-value.doctrine

        use opening: shared.workflow.Opening
#       ^^^ keyword.control.doctrine
#           ^ entity.name.section.doctrine
#                  ^ punctuation.separator.key-value.doctrine
#                    ^ entity.name.type.reference.use-target.doctrine

        inherit read_first
#       ^^^^^^^ keyword.control.doctrine
#               ^^^^^^^^^^ entity.name.section.reference.doctrine

        abstract workflow_core
#       ^^^^^^^^ keyword.control.doctrine
#                ^^^^^^^^^^^^^ entity.name.section.reference.doctrine

        inherit how_to_take_a_turn
#       ^^^^^^^ keyword.control.doctrine
#               ^^^^^^^^^^^^^^^^^^ entity.name.section.reference.doctrine

        override delivery: RevisedDelivery
#       ^^^^^^^^ keyword.control.doctrine
#                ^ entity.name.section.doctrine
#                        ^ punctuation.separator.key-value.doctrine
#                          ^ entity.name.type.reference.override.doctrine

            route "If accepted" -> ProjectLead
#           ^^^^^ keyword.control.doctrine
#                                ^ keyword.operator.route.doctrine
#                                ^ keyword.operator.doctrine
#                                ^ punctuation.separator.route.doctrine
#                                   ^ entity.name.type.reference.route-target.doctrine

    your_job: roles.project_lead.ProjectLeadJob
#   ^^^^^^^^ entity.name.section.doctrine
#           ^ punctuation.separator.key-value.doctrine
#             ^ entity.name.type.reference.key-value.doctrine

    decision: StrategyChoice
#   ^^^^^^^^ keyword.other.field.doctrine
#           ^ punctuation.separator.key-value.doctrine
#             ^^^^^^^^^^^^^^ entity.name.type.reference.key-value.doctrine entity.name.type.doctrine support.type.reference.doctrine

        produced_output: "Produced Output"
#       ^ entity.name.section.doctrine
#                      ^ punctuation.separator.key-value.doctrine
#                        ^ string.quoted.double.doctrine

        CurrentIssue
#       ^^^^^^^^^^^^ entity.name.type.reference.standalone.doctrine

        shared.contracts.TrackMetadata
#       ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ entity.name.type.reference.standalone.doctrine

        ProjectLead
#       ^^^^^^^^^^^ entity.name.type.reference.standalone.doctrine
