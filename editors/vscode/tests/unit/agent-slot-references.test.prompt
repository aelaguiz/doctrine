# SYNTAX TEST "source.doctrine" "agent slot references read like named declarations"

workflow ReadFirst: "Read First"

workflow DossierEngineerJob: "Dossier Engineer Job"

workflow HowToTakeATurn: "How To Take A Turn"

agent SectionDossierEngineer:
    role: "You are Section Dossier Engineer."

    read_first: ReadFirst
#   ^^^^^^^^^^ entity.name.section.doctrine
#                ^^^^^^^^^ entity.name.type.reference.key-value.doctrine

    your_job: DossierEngineerJob
#   ^^^^^^^^ entity.name.section.doctrine
#             ^^^^^^^^^^^^^^^^^^^ entity.name.type.reference.key-value.doctrine

    how_to_take_a_turn: HowToTakeATurn
#   ^^^^^^^^^^^^^^^^^^ entity.name.section.doctrine
