# SYNTAX TEST "source.doctrine" "first-class io blocks and agent io patching"

inputs SharedInputs[shared.io.BaseInputs]: "Your Inputs"
# <---- keyword.declaration.doctrine
#      ^ entity.name.type.doctrine
#                   ^ entity.other.inherited-class.doctrine

outputs SharedOutputs: "Your Outputs"
# <----- keyword.declaration.doctrine
#       ^ entity.name.type.doctrine

    coordination_handoff: "Coordination Handoff Binding"
#   ^^^^^^^^^^^^^^^^^^^^ entity.name.section.doctrine
        CoordinationHandoff
#       ^^^^^^^^^^^^^^^^^^^ support.type.reference.doctrine

agent Reviewer:
    inputs: SharedInputs
#   ^^^^^^ keyword.other.field.doctrine
#           ^^^^^^^^^^^^ entity.name.type.reference.key-value.doctrine

    final_output: CoordinationHandoff
#   ^^^^^^^^^^^^ keyword.other.field.doctrine
#                 ^^^^^^^^^^^^^^^^^^^ entity.name.type.reference.key-value.doctrine

    # Keep split final outputs readable. Editor users should still see
    # review_fields as a reserved field inside the nested final_output body.
    final_output:
#   ^^^^^^^^^^^^ keyword.other.field.doctrine
#               ^ punctuation.separator.key-value.doctrine
        output: CoordinationHandoff
#       ^^^^^^ keyword.other.field.doctrine
#             ^ punctuation.separator.key-value.doctrine
#               ^^^^^^^^^^^^^^^^^^^ entity.name.type.reference.key-value.doctrine

        review_fields:
#       ^^^^^^^^^^^^^ keyword.other.field.doctrine
#                    ^ punctuation.separator.key-value.doctrine
            current_artifact: current_artifact
#           ^^^^^^^^^^^^^^^^ keyword.other.field.doctrine
#                           ^ punctuation.separator.key-value.doctrine
#                             ^^^^^^^^^^^^^^^^ entity.name.type.reference.key-value.doctrine

output schema WriterDecisionSchema: "Writer Decision Schema"
# <---- keyword.declaration.doctrine
#      ^^^^^^ keyword.declaration.doctrine
#             ^^^^^^^^^^^^^^^^^^^^ entity.name.type.doctrine

    route field next_route: "Next Route"
#   ^^^^^ keyword.other.field.doctrine
#         ^^^^^ keyword.other.field.doctrine
#               ^^^^^^^^^^ entity.name.section.doctrine
#                         ^ punctuation.separator.key-value.doctrine
#                           ^^^^^^^^^^^^ string.quoted.double.doctrine

        seek_muse: "Send to Muse." -> Muse
#       ^^^^^^^^^ entity.name.section.doctrine
#                ^ punctuation.separator.key-value.doctrine
#                  ^^^^^^^^^^^^^^^ string.quoted.double.doctrine
#                                      ^^^^ entity.name.type.reference.key-value.doctrine

    override route field next_route: "Next Route"
#   ^^^^^^^^ keyword.control.doctrine
#            ^^^^^ keyword.other.field.doctrine
#                  ^^^^^ keyword.other.field.doctrine
#                        ^^^^^^^^^^ entity.name.section.doctrine
#                                  ^ punctuation.separator.key-value.doctrine
#                                    ^^^^^^^^^^^^ string.quoted.double.doctrine

agent Writer:
    final_output:
        output: CoordinationHandoff
        route: next_route
#       ^^^^^ keyword.other.field.doctrine
#            ^ punctuation.separator.key-value.doctrine
#              ^^^^^^^^^^ variable.other.member.doctrine

    outputs[SharedOutputs]: "Your Outputs"
#   ^^^^^^^ keyword.other.field.doctrine
#          ^ punctuation.section.inheritance.begin.doctrine
#           ^^^^^^^^^^^^^ entity.other.inherited-class.doctrine
#                        ^ punctuation.section.inheritance.end.doctrine
#                         ^ punctuation.separator.key-value.doctrine

        inherit {durable_section_truth, scoped_catalog_truth}
#       ^^^^^^^ keyword.control.doctrine
#               ^ punctuation.section.inheritance.begin.doctrine
#                ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ entity.name.section.reference.doctrine
#                                                           ^ punctuation.section.inheritance.end.doctrine
