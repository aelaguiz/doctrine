#          ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt meta.emphasis.note.pyprompt string.quoted.double.pyprompt
#                                                  ^ source.pyprompt meta.emphasis.note.pyprompt punctuation.definition.string.end.pyprompt
>
>
>agent EmphasizedProseLinesDemo:
