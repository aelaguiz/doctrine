># This example adds one narrow prose-line feature:
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># fixed emphasis labels can lead certain prose lines without embedding raw markdown.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>#
#^ source.pyprompt comment.line.number-sign.pyprompt
># The supported labels are `required`, `important`, `warning`, and `note`.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># They work in workflow prose, role blocks, and record prose surfaces.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># Workflow emphasis lines still support `{{...}}` interpolation.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>
>input CurrentPlan: "Current Plan"
#^^^^^ source.pyprompt keyword.declaration.pyprompt
#     ^ source.pyprompt
#      ^^^^^^^^^^^ source.pyprompt entity.name.type.pyprompt
#                 ^ source.pyprompt punctuation.separator.key-value.pyprompt
#                  ^ source.pyprompt
#                   ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#                    ^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                                ^ source.pyprompt punctuation.definition.string.end.pyprompt
>    source: File
#^^^^ source.pyprompt
#    ^^^^^^ source.pyprompt entity.name.section.pyprompt
#          ^ source.pyprompt punctuation.separator.key-value.pyprompt
#           ^ source.pyprompt
#            ^^^^ source.pyprompt support.type.reference.pyprompt
>        path: "track_root/current-plan.md"
#^^^^^^^^ source.pyprompt
#        ^^^^ source.pyprompt entity.name.section.pyprompt
#            ^ source.pyprompt punctuation.separator.key-value.pyprompt
#             ^ source.pyprompt
#              ^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
>    shape: MarkdownDocument
#^^^^ source.pyprompt
#    ^^^^^ source.pyprompt entity.name.section.pyprompt
#         ^ source.pyprompt punctuation.separator.key-value.pyprompt
#          ^ source.pyprompt
#           ^^^^^^^^^^^^^^^^ source.pyprompt support.type.reference.pyprompt
>    requirement: Required
#^^^^ source.pyprompt
#    ^^^^^^^^^^^ source.pyprompt entity.name.section.pyprompt
#               ^ source.pyprompt punctuation.separator.key-value.pyprompt
#                ^ source.pyprompt
#                 ^^^^^^^^ source.pyprompt support.type.reference.pyprompt
>    note "Use this file as the current plan truth."
#^^^^ source.pyprompt meta.emphasis.note.pyprompt
#    ^^^^ source.pyprompt meta.emphasis.note.pyprompt keyword.control.emphasis.note.pyprompt
#        ^ source.pyprompt meta.emphasis.note.pyprompt
