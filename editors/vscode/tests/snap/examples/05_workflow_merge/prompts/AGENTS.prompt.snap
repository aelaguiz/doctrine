#               ^ source.pyprompt
#                ^^^^^^^^^^^^^^^^ source.pyprompt support.type.reference.pyprompt
>        inherit closing
#^^^^^^^^ source.pyprompt
#        ^^^^^^^ source.pyprompt keyword.control.pyprompt
#               ^ source.pyprompt
#                ^^^^^^^ source.pyprompt support.type.reference.pyprompt
>
>        follow_up: "Follow Up"
#^^^^^^^^ source.pyprompt
#        ^^^^^^^^^ source.pyprompt entity.name.section.pyprompt
#                 ^ source.pyprompt punctuation.separator.key-value.pyprompt
#                  ^ source.pyprompt
