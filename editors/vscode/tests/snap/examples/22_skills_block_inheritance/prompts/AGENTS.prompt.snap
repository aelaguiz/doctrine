># This example adds inheritance and explicit patching for named `skills` blocks.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>#
#^ source.pyprompt comment.line.number-sign.pyprompt
># The rules match workflow-style patching:
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># - inherited entries must be accounted for exactly once
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># - `inherit` keeps a parent entry as-is
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># - `override` replaces a parent entry by key
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>#
#^ source.pyprompt comment.line.number-sign.pyprompt
># Individual skill entries now carry stable keys so top-level skills blocks can
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># patch them cleanly.
#^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>
>skill GroundingSkill: "Grounding Skill"
#^^^^^ source.pyprompt keyword.declaration.pyprompt
#     ^ source.pyprompt
#      ^^^^^^^^^^^^^^ source.pyprompt entity.name.type.pyprompt
#                    ^ source.pyprompt punctuation.separator.key-value.pyprompt
#                     ^ source.pyprompt
#                      ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#                       ^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                                      ^ source.pyprompt punctuation.definition.string.end.pyprompt
>    purpose: "Ground the current claim before you write."
#^^^^ source.pyprompt
#    ^^^^^^^ source.pyprompt entity.name.section.pyprompt
#           ^ source.pyprompt punctuation.separator.key-value.pyprompt
#            ^ source.pyprompt
#             ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#              ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                                                        ^ source.pyprompt punctuation.definition.string.end.pyprompt
>
>
