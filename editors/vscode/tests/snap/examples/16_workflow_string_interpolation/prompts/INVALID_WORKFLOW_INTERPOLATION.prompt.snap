># Workflow refs are intentionally not valid inside workflow-string interpolation.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
># Use `use` when a workflow needs to compose another workflow.
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>
>workflow SharedRead: "Shared Read"
#^^^^^^^^ source.pyprompt keyword.declaration.pyprompt
#        ^ source.pyprompt
#         ^^^^^^^^^^ source.pyprompt entity.name.type.pyprompt
#                   ^ source.pyprompt punctuation.separator.key-value.pyprompt
#                    ^ source.pyprompt
#                     ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#                      ^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                                 ^ source.pyprompt punctuation.definition.string.end.pyprompt
>    first: "First"
#^^^^ source.pyprompt
#    ^^^^^ source.pyprompt entity.name.section.pyprompt
#         ^ source.pyprompt punctuation.separator.key-value.pyprompt
#          ^ source.pyprompt
#           ^^^^^^^ source.pyprompt string.quoted.double.pyprompt
>        "Read this first."
#^^^^^^^^ source.pyprompt
#        ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#         ^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                         ^ source.pyprompt punctuation.definition.string.end.pyprompt
>
>
>workflow InvalidWorkflowStringInterpolation: "Invalid Workflow String Interpolation"
#^^^^^^^^ source.pyprompt keyword.declaration.pyprompt
#        ^ source.pyprompt
#         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt entity.name.type.pyprompt
#                                           ^ source.pyprompt punctuation.separator.key-value.pyprompt
#                                            ^ source.pyprompt
#                                             ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#                                              ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                                                                                   ^ source.pyprompt punctuation.definition.string.end.pyprompt
>    bad: "Bad"
#^^^^ source.pyprompt
#    ^^^ source.pyprompt entity.name.section.pyprompt
#       ^ source.pyprompt punctuation.separator.key-value.pyprompt
#        ^ source.pyprompt
#         ^^^^^ source.pyprompt string.quoted.double.pyprompt
>        "Read {{SharedRead}} before you continue."
#^^^^^^^^ source.pyprompt
#        ^ source.pyprompt punctuation.definition.string.begin.pyprompt
#         ^^^^^ source.pyprompt string.quoted.double.pyprompt
#              ^^ source.pyprompt string.quoted.double.pyprompt punctuation.definition.interpolation.begin.pyprompt
#                ^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt support.type.reference.pyprompt
#                          ^^ source.pyprompt string.quoted.double.pyprompt punctuation.definition.interpolation.end.pyprompt
#                            ^^^^^^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
#                                                 ^ source.pyprompt punctuation.definition.string.end.pyprompt
>
>
>agent InvalidWorkflowStringInterpolationAgent:
#^^^^^ source.pyprompt keyword.declaration.pyprompt
