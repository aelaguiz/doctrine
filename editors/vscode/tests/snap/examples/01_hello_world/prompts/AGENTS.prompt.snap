>agent HelloWorld:
#^^^^^ source.pyprompt keyword.declaration.pyprompt
#     ^ source.pyprompt
#      ^^^^^^^^^^ source.pyprompt entity.name.type.pyprompt
#                ^ source.pyprompt punctuation.separator.key-value.pyprompt
>    # When there is no body beneath the key: heading it renders as plain text
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt comment.line.number-sign.pyprompt
>    role: "You are the hello world agent."
#^^^^ source.pyprompt
#    ^^^^ source.pyprompt keyword.other.field.pyprompt
#        ^ source.pyprompt punctuation.separator.key-value.pyprompt
#         ^ source.pyprompt
#          ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
>
>    workflow: "Instruction"
#^^^^ source.pyprompt
#    ^^^^^^^^ source.pyprompt entity.name.section.pyprompt
#            ^ source.pyprompt punctuation.separator.key-value.pyprompt
#             ^ source.pyprompt
#              ^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
>        "Say hello world."
#^^^^^^^^ source.pyprompt
#        ^^^^^^^^^^^^^^^^^^ source.pyprompt string.quoted.double.pyprompt
>
