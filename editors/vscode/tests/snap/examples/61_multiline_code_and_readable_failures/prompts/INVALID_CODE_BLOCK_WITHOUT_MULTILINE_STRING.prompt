output BrokenGuide: "Broken Guide"
    target: File
        path: "release_root/BROKEN_GUIDE.md"
    shape: MarkdownDocument
    requirement: Required

    code example_manifest: "Example Manifest"
        language: json
        text: "not multiline"


agent InvalidCodeBlockDemo:
