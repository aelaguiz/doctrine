enum ExactMoveProofNeeded: "Exact Move Proof Needed"
    yes: "Yes"
    no: "No"

skill StudioSkill: "Studio Skill"
    purpose: "Run the studio job."
    package: "studio-skill"

stage SituationSynthesis: "Situation Synthesis"
    owner: StudioSkill
    intent: "Build situations from approved plan."
    durable_target: "Situation brief."
    durable_evidence: "Situation receipt."
    advance_condition: "Situation receipt landed."

stage ExactMoveProof: "Exact Move Proof"
    owner: StudioSkill
    intent: "Prove the exact action."
    durable_target: "Move proof."
    durable_evidence: "Proof receipt."
    advance_condition: "Proof receipt landed."

skill_flow F1AuthorLesson: "F1 - Author One Lesson"
    intent: "Branch coverage missing one enum member."
    start: SituationSynthesis
    edge SituationSynthesis -> ExactMoveProof:
        when: ExactMoveProofNeeded.yes
        why: "Only the yes branch is declared; the no branch is missing."

agent FlowDemo:
    role: "Run the missing-branch flow."
