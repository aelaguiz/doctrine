# This capstone combines the full shipped review bundle in one durable review:
# handoff-first blocking, exact shared-contract gates, comparison-only support,
# rewrite-evidence exclusions, preserved truth, multi-subject current truth,
# carried mode and trigger reason, and blocked outcomes that honestly keep no
# durable artifact current.

# Declare the active review mode that selects the live reviewed subject.
enum ReviewMode: "Review Mode"
    draft_rewrite: "draft-rewrite"
    metadata_refresh: "metadata-refresh"


# Declare the trigger reason that explains why the next owner receives the
# current artifact under a given mode.
enum TriggerReason: "Trigger Reason"
    structure_gap: "structure-gap"
    stale_metadata: "stale-metadata"


# Declare the host handoff facts that must be trustworthy before review may
# continue to content review.
input ProducerHandoff: "Producer Handoff"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the producer handoff that says whether the handoff is complete and whether it named the wrong current artifact."


# Declare the host review facts that pick the active review mode and note any
# local scope leak or comparison-only usage.
input ReviewState: "Review State"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the review state. It says which mode is active, whether peer comparison was used, whether the current artifact fell outside this review family, whether metadata-refresh exclusions apply, whether scope leaked, and why the next owner must act."


# Declare the two subject artifacts that may be reviewed under this family.
input DraftSpec: "Draft Spec"
    source: File
        path: "unit_root/DRAFT_SPEC.md"
    shape: MarkdownDocument
    requirement: Required
    "Use the current draft specification when the active mode is draft rewrite."


input MetadataRecord: "Metadata Record"
    source: File
        path: "unit_root/METADATA.json"
    shape: JsonObject
    requirement: Required
    "Use the current metadata record when the active mode is metadata refresh."


# Declare the preserved boundary that the review must keep exact.
input ApprovedBoundary: "Approved Boundary"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the approved boundary facts that define the exact scope the review must preserve."


# Declare advisory comparison help that may inform the review without becoming
# durable current truth.
input AcceptedPeerSet: "Accepted Peer Set"
    source: File
        path: "catalog/accepted_peers.json"
    shape: JsonObject
    requirement: Advisory
    "Use accepted peer examples only for comparison when the review state says peer comparison was used."


# Declare the shared contract whose keyed sections export exact gate
# identities.
workflow CapstoneReviewContract: "Capstone Review Contract"
    completeness: "Completeness"
        "Confirm the selected subject covers the required review basis."

    clarity: "Clarity"
        "Confirm the selected subject keeps the core decision clear."

    handoff_truth: "Handoff Truth"
        "Confirm the producer handoff names the same current artifact this review family is about."


# Declare the owners who receive blocked, accepted, or rejected work.
agent ReviewLead:
    role: "Own blocked or unresolved review follow-up."
    workflow: "Review Lead Follow Up"
        "Take blocked or unresolved review work back when the next specialist owner cannot be named honestly."


agent DraftAuthor:
    role: "Repair draft defects after review."
    workflow: "Draft Revision"
        "Revise the current draft when the review keeps draft work local."


agent MetadataAuthor:
    role: "Repair metadata defects after review."
    workflow: "Metadata Revision"
        "Revise the current metadata record when the review keeps metadata work local."


# Declare the one durable review comment that carries the verdict, exact
# reviewed artifact, current truth when present, and typed downstream state.
output CapstoneReviewComment: "Capstone Review Comment"
    target: TurnResponse
    shape: Comment
    requirement: Required

    verdict: "Verdict"
        "Say whether the review accepted the selected subject or asked for changes."

    reviewed_artifact: "Reviewed Artifact"
        "Name the exact artifact this review judged. If a handoff-first block stopped review before content review began, name the producer handoff instead."

    analysis_performed: "Analysis Performed"
        "Sum up the review work that led to the verdict. Say how {{fields.reviewed_artifact}} met or did not meet {{contract.clarity}}. Note any preserved boundary, comparison-only help, and rewrite-evidence exclusions that mattered."

    output_contents_that_matter: "Output Contents That Matter"
        "Sum up the exact parts the next owner should read first. Include any preserved boundary or rewrite-only exclusions that still matter."

    current_artifact: "Current Artifact" when present(current_artifact):
        "Name the artifact that stays current after this review outcome. Leave this out for blocked handoff-first outcomes, because no later artifact became current."

    next_owner: "Next Owner"
        "Name the next owner. Use {{ReviewLead}} for blocked or unresolved review, {{DraftAuthor}} for draft work, and {{MetadataAuthor}} for metadata work."

    active_mode: "Active Mode" when present(active_mode):
        "Name the active review mode for the current artifact."

    trigger_reason: "Trigger Reason" when present(trigger_reason):
        "Name the trigger reason for this live mode and artifact."

    failure_detail: "Failure Detail" when verdict == ReviewVerdict.changes_requested:
        failing_gates: "Failing Gates"
            "List each failed review gate in authored order, including exact shared-contract gate names."

        blocked_gate: "Blocked Gate" when present(blocked_gate):
            "Name the first blocking gate when the review stopped before content review started."

    trust_surface:
        current_artifact when present(current_artifact)
        active_mode when present(active_mode)
        trigger_reason when present(trigger_reason)

    standalone_read: "Standalone Read"
        "This comment should stand on its own. The next owner should know if review was blocked or done, what was reviewed, what is still current, which mode and trigger reason are live, who owns next, and which exact failures still matter."


# Declare the capstone review itself. It keeps all review semantics inside one
# compiler-owned surface instead of splitting them across side channels.
review CapstoneReview: "Capstone Review"
    subject: {DraftSpec, MetadataRecord}
    subject_map:
        ReviewMode.draft_rewrite: DraftSpec
        ReviewMode.metadata_refresh: MetadataRecord
    contract: CapstoneReviewContract
    comment_output: CapstoneReviewComment

    fields:
        verdict: verdict
        reviewed_artifact: reviewed_artifact
        analysis: analysis_performed
        readback: output_contents_that_matter
        failing_gates: failure_detail.failing_gates
        blocked_gate: failure_detail.blocked_gate
        next_owner: next_owner
        active_mode: active_mode
        trigger_reason: trigger_reason

    start_review: "Start Review"
        block "Producer handoff is incomplete." when ProducerHandoff.invalid
        block "Current review mode is implicit." when unclear(ReviewState.active_mode)
        reject contract.handoff_truth when ProducerHandoff.names_wrong_current_artifact
        reject "Producer handoff named an artifact outside this review family." when ReviewState.artifact_outside_review_family

    evidence_checks: "Evidence Checks"
        support_only AcceptedPeerSet for comparison when ReviewState.peer_comparison_used
        ignore MetadataRecord.previous_summary for rewrite_evidence when ReviewState.metadata_refresh_active
        preserve exact ApprovedBoundary.exact_scope_boundary
        reject contract.clarity when ReviewState.scope_leak
        accept "The shared capstone review contract passes." when contract.passes

    on_accept: "If Accepted"
        match ReviewState.active_mode:
            ReviewMode.draft_rewrite:
                current artifact DraftSpec via CapstoneReviewComment.current_artifact
                carry active_mode = ReviewMode.draft_rewrite
                carry trigger_reason = TriggerReason.structure_gap
                route "Accepted draft rewrite goes to DraftAuthor." -> DraftAuthor

            ReviewMode.metadata_refresh:
                current artifact MetadataRecord via CapstoneReviewComment.current_artifact
                carry active_mode = ReviewMode.metadata_refresh
                carry trigger_reason = TriggerReason.stale_metadata
                route "Accepted metadata refresh goes to MetadataAuthor." -> MetadataAuthor

    on_reject: "If Rejected"
        match ReviewState.active_mode:
            ReviewMode.draft_rewrite when ProducerHandoff.invalid:
                current none
                route "Blocked handoff review goes to ReviewLead." -> ReviewLead

            ReviewMode.draft_rewrite:
                current artifact DraftSpec via CapstoneReviewComment.current_artifact
                carry active_mode = ReviewMode.draft_rewrite
                carry trigger_reason = TriggerReason.structure_gap
                route "Rejected draft rewrite goes to DraftAuthor." -> DraftAuthor

            ReviewMode.metadata_refresh when ProducerHandoff.invalid:
                current none
                route "Blocked handoff review goes to ReviewLead." -> ReviewLead

            ReviewMode.metadata_refresh:
                current artifact MetadataRecord via CapstoneReviewComment.current_artifact
                carry active_mode = ReviewMode.metadata_refresh
                carry trigger_reason = TriggerReason.stale_metadata
                route "Rejected metadata refresh goes to MetadataAuthor." -> MetadataAuthor

            else:
                current none
                route "Blocked mode selection review goes to ReviewLead." -> ReviewLead


# Declare the concrete reviewer agent that emits the capstone review comment.
agent CapstoneReviewDemo:
    role: "Keep the full review bundle coherent, explicit, and durable."
    review: CapstoneReview
    inputs: "Inputs"
        ProducerHandoff
        ReviewState
        DraftSpec
        MetadataRecord
        ApprovedBoundary
        AcceptedPeerSet
    outputs: "Outputs"
        CapstoneReviewComment
