# This file proves that shared review contracts export exact gate identities.
# The review can reject on `contract.some_gate`, and the emitted comment can
# promise those exact exported gate names instead of collapsing them to vague
# pass or fail prose.

# Declare the draft specification under review.
input DraftSpec: "Draft Spec"
    source: File
        path: "unit_root/DRAFT_SPEC.md"
    shape: MarkdownDocument
    requirement: Required
    "Use the current draft spec as the reviewed artifact."


# Declare the shared review contract with three exported gate identities.
workflow ExactGateReviewContract: "Exact Gate Review Contract"
    completeness: "Completeness"
        "Confirm the draft covers the required sections."

    clarity: "Clarity"
        "Confirm the draft states the next action clearly."

    handoff_truth: "Handoff Truth"
        "Confirm the draft says who owns next after this review."


# Declare the owners who receive accepted and rejected drafts.
agent ReviewLead:
    role: "Own accepted draft follow-up."
    workflow: "Follow Up"
        "Take the accepted draft to the next planning step."


agent DraftAuthor:
    role: "Repair rejected draft defects."
    workflow: "Revise"
        "Revise the same draft when review requests changes."


# Declare the durable review comment.
output ExactGateReviewComment: "Exact Gate Review Comment"
    target: TurnResponse
    shape: Comment
    requirement: Required

    verdict: "Verdict"
        "Say whether the review accepted the draft or asked for changes."

    reviewed_artifact: "Reviewed Artifact"
        "Name the reviewed artifact this review judged."

    analysis_performed: "Analysis Performed"
        "Sum up the review work that led to the verdict."

    output_contents_that_matter: "Output Contents That Matter"
        "Summarize the parts of the draft the next owner must read first."

    next_owner: "Next Owner"
        "Name the next owner. Use {{ReviewLead}} when the draft is accepted and {{DraftAuthor}} when it is rejected."

    failure_detail: "Failure Detail" when verdict == ReviewVerdict.changes_requested:
        failing_gates: "Failing Gates"
            "List the exact shared-contract gate names in authored order, including {{contract.completeness}}, {{contract.clarity}}, and {{contract.handoff_truth}} when they fail."

    standalone_read: "Standalone Read"
        "This comment should stand on its own. The next owner should know what {{fields.reviewed_artifact}} was reviewed, what verdict landed, who owns next, and which shared contract gates failed."


# Declare the review that uses explicit contract-gate references.
review ExactGateReview: "Exact Gate Review"
    subject: DraftSpec
    contract: ExactGateReviewContract
    comment_output: ExactGateReviewComment

    fields:
        verdict: verdict
        reviewed_artifact: reviewed_artifact
        analysis: analysis_performed
        readback: output_contents_that_matter
        failing_gates: failure_detail.failing_gates
        next_owner: next_owner

    contract_gate_checks: "Contract Gate Checks"
        # These lines reject on exact exported contract gate identities.
        reject contract.clarity when DraftSpec.next_action_missing
        reject contract.handoff_truth when DraftSpec.next_owner_missing
        accept "The shared review contract passes." when contract.passes

    on_accept: "If Accepted"
        current none
        route "Accepted draft goes to ReviewLead." -> ReviewLead

    on_reject: "If Rejected"
        current none
        route "Rejected draft goes to DraftAuthor." -> DraftAuthor


# Declare the concrete reviewer agent.
agent ExactGateReviewDemo:
    role: "Keep exact shared-contract gate identities visible in review output."
    review: ExactGateReview
    inputs: "Inputs"
        DraftSpec
    outputs: "Outputs"
        ExactGateReviewComment
