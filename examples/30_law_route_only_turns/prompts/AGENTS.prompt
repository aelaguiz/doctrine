# This file is the narrow route-only setup example.
# It introduces `current none`, stop lines, and explicit reroute before the
# richer route-only handoff examples later in the ladder.
import shared.owners

# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input CurrentHandoff: "Current Handoff"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the host-provided handoff facts that say whether the current handoff is missing or unclear."


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output CoordinationComment: "Coordination Comment"
    target: TurnResponse
    shape: Comment
    requirement: Required

    # This block says what a downstream owner should understand just from reading this output.
    standalone_read: "Standalone Read"
        "A downstream owner should be able to read this comment alone and understand that no current artifact was carried forward."


# Declare a concrete agent that wires role text, workflow rules, and the needed inputs and outputs together.
agent RoutingOwner:
    role: "Own explicit reroutes when specialist work cannot continue."
    workflow: "Instructions"
        "Take back the same issue when route-only work cannot continue safely."


# Declare a reusable workflow. The title is human-facing, and the indented body
# holds prose plus checked law.
workflow RouteOnlyTriage: "Route-Only Triage"
    "Handle turns that can only stop and reroute."

    # This block holds the machine-checked rules for the turn.
    law:
        # This line turns the workflow on only when the condition is true.
        active when CurrentHandoff.missing or CurrentHandoff.unclear

        # This block applies only when the condition is true inside the surrounding law context.
        when CurrentHandoff.missing:
            # This line says the branch carries no durable artifact forward.
            current none
            # This line ends the turn with an explicit reason.
            stop "Current handoff is missing."
            # This line sends the same work to a named owner with an explicit message.
            route "Route the same issue back to {{RoutingOwner:name}}." -> RoutingOwner

        # This block applies only when the condition is true inside the surrounding law context.
        when CurrentHandoff.unclear:
            # This line says the branch carries no durable artifact forward.
            current none
            # This line ends the turn with an explicit reason.
            stop "Current handoff is unclear."
            # This line sends the same work to a named owner with an explicit message.
            route "Route the same issue back to {{RoutingOwner:name}}." -> RoutingOwner


# Declare a concrete agent that wires the narrow setup example together.
agent RouteOnlyTriageDemo:
    role: "Set up route-only law before the richer handoff examples."
    workflow: RouteOnlyTriage
    inputs: "Inputs"
        CurrentHandoff
    outputs: "Outputs"
        CoordinationComment


workflow ImportedRouteOnlyTriage: "Imported Route-Only Triage"
    "Prove that workflow-law route labels interpolate imported agent refs too."

    law:
        active when CurrentHandoff.missing
        current none
        stop "Current handoff is missing."
        route "Route the same issue back to {{shared.owners.ImportedRoutingOwner:name}}." -> shared.owners.ImportedRoutingOwner


agent ImportedRouteOnlyTriageDemo:
    role: "Keep imported workflow-law route labels readable."
    workflow: ImportedRouteOnlyTriage
    inputs: "Inputs"
        CurrentHandoff
    outputs: "Outputs"
        CoordinationComment
