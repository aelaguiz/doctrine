skill StudioSkill: "Studio Skill"
    purpose: "Run the studio job."
    package: "studio-skill"

stage ControllerRecoveryAudit: "Controller Recovery Audit"
    owner: StudioSkill
    intent: "Audit recovery state."
    durable_target: "Audit brief."
    durable_evidence: "Audit receipt."
    advance_condition: "Audit receipt landed."

skill_flow F1: "F1"
    intent: "Inner flow."
    start: ControllerRecoveryAudit

skill_flow F2: "F2"
    intent: "Repeat over: ref does not resolve."
    start: ControllerRecoveryAudit
    repeat LessonSlotRun: F1
        over: MissingCollection
        order: serial
        why: "Over ref does not resolve."

agent FlowDemo:
    role: "Run the bad-over flow."
