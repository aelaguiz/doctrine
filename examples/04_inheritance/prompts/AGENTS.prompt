agent BaseAgent:
    role: "You are the base agent."

    workflow:
        "Follow the base steps below."

        greeting: "Greeting"
            "Say hello."

        object: "Object"
            "Say world."


# This child shows the simplest explicit inheritance pattern.
# - `inherit greeting` keeps the inherited section and places it here
# - `override object:` replaces the inherited section and keeps the inherited title
agent InheritanceDemo[BaseAgent]:
    role: "You are the inheritance demonstration agent."

    workflow:
        "Follow the inherited steps below."
        "This child keeps the greeting and replaces the final step."

        inherit greeting

        override object:
            "Say inherited world."
