direction: down

local_inputs: {
  label: "Local Inputs"
  direction: down
  style: {
    fill: "#F8FAFC"
    stroke: "#94A3B8"
  }
  input_draftspec: {
    label: "Draft Spec\nInput\nSource: File\nPath: unit_root/DRAFT_SPEC.md\nShape: Markdown Document\nRequirement: Required\nUsed by: DraftReviewSplitFinal\nOutputDemo"
    shape: rectangle
    style: {
      fill: "#E8F1FF"
      stroke: "#2F6FEB"
    }
  }
}

agent_handoffs: {
  label: "Agent Handoffs"
  direction: down
  style: {
    fill: "#FFF8EB"
    stroke: "#B54708"
  }
  primary_lane: {
    label: ""
    direction: down
    style: {
      fill: "transparent"
      stroke: "transparent"
    }
    agent_reviewlead: {
      label: "ReviewLead\nAgent\nOwn accepted draft follow-up."
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }

    agent_draftauthor: {
      label: "DraftAuthor\nAgent\nFix rejected draft defects."
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }

    agent_draftreviewsplitfinaloutputdemo: {
      label: "DraftReviewSplitFinalOutputDem\no\nAgent\nEmit the rich review comment\nand a small final control\nsummary."
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }
  }
}

shared_outputs_and_carriers: {
  label: "Shared Outputs And Carriers"
  direction: down
  style: {
    fill: "#F3FFF8"
    stroke: "#067647"
  }
  output_draftreviewcomment: {
    label: "Draft Review Comment\nCarrier Output\nTarget: Turn Response\nShape: Comment\nRequirement: Required\nProduced by: DraftReviewSplitF\ninalOutputDemo\nTrust: Current Artifact"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_draftreviewdecision: {
    label: "Draft Review Decision\nCarrier Output\nTarget: Turn Response\nShape: Comment Text\nRequirement: Required\nProduced by: DraftReviewSplitF\ninalOutputDemo\nTrust: Current Artifact"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }
}

local_inputs.input_draftspec -> agent_handoffs.primary_lane.agent_draftreviewsplitfinaloutputdemo: {
  label: "consumes"
  style: {
    stroke: "#5B708B"
    stroke-dash: 4
  }
}

agent_handoffs.primary_lane.agent_draftreviewsplitfinaloutputdemo -> shared_outputs_and_carriers.output_draftreviewcomment: {
  label: "produces"
  style: {
    stroke: "#067647"
    stroke-dash: 4
  }
}

agent_handoffs.primary_lane.agent_draftreviewsplitfinaloutputdemo -> shared_outputs_and_carriers.output_draftreviewdecision: {
  label: "produces"
