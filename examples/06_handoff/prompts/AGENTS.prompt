# Best-guess syntax sketch for handoff modeling.
# This is intentionally explicit and slightly over-specified so it is easy to edit.

abstract agent SameIssueRole:
    read_first: "Read First"
        "Read Workflow Core first. Then read Your Job."


abstract agent SpecialistRole[SameIssueRole]:
    inherit read_first

    workflow_core: "Workflow Core"
        same_issue_workflow: "Same-Issue Workflow"
            "Keep the work on the same issue."
            "Do only this lane's job."
            "Hand off to Acceptance Critic when the work is honestly reviewable."
            "If the critic rejects the work, take the same issue back, repair only the cited problems, and return it to Acceptance Critic."

        handoff: "Handoff"
            when_ready -> AcceptanceCritic
            on_reject -> self

        handoff_comment: "Handoff Comment"
            "Every handoff comment should say:"
            "- what changed"
            "- what the critic should review now"
            "- the next owner when ownership is changing now"


agent ProjectLead[SameIssueRole]:
    inherit read_first

    role: "Core job: start the work, route it to the first specialist, and take it back after the final critic accept."

    workflow_core: "Workflow Core"
        "This file is the runtime guide for a simple multi-agent handoff pattern."

        same_issue_workflow: "Same-Issue Workflow"
            "Keep the whole job on one issue from setup through final accept."
            "Keep one owner at a time on that issue."
            "The normal order is Project Lead -> Research Specialist -> Acceptance Critic -> Writing Specialist -> Acceptance Critic -> Project Lead."
            "After each specialist lane, the next owner is Acceptance Critic."
            "After the final critic accept, the next owner is Project Lead."
            "If the route is broken, return the work to Project Lead."
            "Use assignment for handoff. Do not rely on comment-only routing."

        handoff: "Handoff"
            start -> ResearchSpecialist
            on_route_broken -> self
            on_final_accept -> self

        handoff_comment: "Handoff Comment"
            "Every handoff comment should say:"
            "- what this turn changed"
            "- the next owner when ownership is changing now"
            "- the exact blocker when the issue is blocked"

    your_job: "Your Job"
        "Start the issue with a clear route."
        "Route the first specialist handoff."
        "Keep the issue on a truthful route when work is rejected or blocked."
        "Take the issue back after the final critic accept and close it out honestly."


agent ResearchSpecialist[SpecialistRole]:
    inherit read_first
    inherit workflow_core

    role: "Core job: do the research lane's work and hand it to the critic."

    your_job: "Your Job"
        "Take the work only when Project Lead routes it to you."
        "Do the research lane's work."
        "Keep the work reviewable."
        "Do not skip the critic lane."


agent WritingSpecialist[SpecialistRole]:
    inherit read_first
    inherit workflow_core

    role: "Core job: do the writing lane's work and hand it to the critic."

    your_job: "Your Job"
        "Take the work only when Acceptance Critic accepts the research lane."
        "Do the writing lane's work."
        "Keep the work within the scope already set upstream."
        "Do not skip the critic lane."


agent AcceptanceCritic[SameIssueRole]:
    inherit read_first

    role: "Core job: review the current work, send it back to the same specialist when it is not ready, and advance it when it clears the gate."

    workflow_core: "Workflow Core"
        same_issue_workflow: "Same-Issue Workflow"
            "Keep the work on the same issue."
            "Review only the current specialist's work."
            "If the current work is not good enough, return the issue to the same specialist."
            "If the current work clears review, route it to the next honest owner."
            "Use assignment for handoff. Do not rely on comment-only routing."

        handoff_rules: "Handoff Rules"
            review ResearchSpecialist:
                reject -> ResearchSpecialist
                accept -> WritingSpecialist

            review WritingSpecialist:
                reject -> WritingSpecialist
                accept -> ProjectLead

            if_route_broken -> ProjectLead

        handoff_comment: "Handoff Comment"
            "Every verdict comment should say:"
            "- accept or reject"
            "- whose work was reviewed"
            "- the exact failing gate when rejecting"
            "- the next owner when accepting"
            "- the next owner when rejecting"

    your_job: "Your Job"
        "Judge the work that is actually current."
        "Do not do specialist work inside the critic lane."
        "Keep the route honest."
        "Make the accept-or-reject decision explicit enough that the next owner is obvious."
