direction: down

shared_inputs: {
  label: "Shared Inputs"
  direction: down
  style: {
    fill: "#F5F8FF"
    stroke: "#2F6FEB"
  }
  input_7bcf353c_currenthandoff: {
    label: "Current Handoff\nShared Input\nSource: Prompt\nShape: Json Object\nRequirement: Required\nUsed by:\nBlockedSectionReviewDemo,\nRebuildSectionReviewDemo,\nStructureChangeDemo"
    shape: rectangle
    style: {
      fill: "#E8F1FF"
      stroke: "#2F6FEB"
    }
  }
}

agent_handoffs: {
  label: "Agent Handoffs"
  direction: right
  style: {
    fill: "#FFF8EB"
    stroke: "#B54708"
  }
  route_starts: {
    label: ""
    direction: down
    style: {
      fill: "transparent"
      stroke: "transparent"
    }
    agent_7bcf353c_structurechangedemo: {
      label: "StructureChangeDemo\nAgent\nInvalidate downstream review\nwhen structure changes."
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }

    agent_7bcf353c_blockedsectionreviewdemo: {
      label: "BlockedSectionReviewDemo\nAgent\nDo not keep reviewing against\ninvalidated downstream truth.\nMay end with no current\nartifact"
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }
  }

  primary_lane: {
    label: ""
    direction: down
    style: {
      fill: "transparent"
      stroke: "transparent"
    }
    agent_7bcf353c_routingowner: {
      label: "RoutingOwner\nAgent\nHandle reroutes when\nspecialist work cannot\ncontinue."
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }
  }

  secondary_lanes: {
    label: ""
    direction: down
    style: {
      fill: "transparent"
      stroke: "transparent"
    }
    agent_7bcf353c_rebuildsectionreviewdemo: {
      label: "RebuildSectionReviewDemo\nAgent\nRebuild invalidated review\nwork and reissue it as current\ntruth."
      shape: rectangle
      style: {
        fill: "#FFF7E6"
        stroke: "#B54708"
      }
    }
  }
}

shared_outputs_and_carriers: {
  label: "Shared Outputs And Carriers"
  direction: down
  style: {
    fill: "#F3FFF8"
    stroke: "#067647"
  }
  output_7bcf353c_invalidationhandoff: {
    label: "Invalidation Handoff\nCarrier Output\nTarget: Turn Response\nShape: Comment\nRequirement: Required\nProduced by:\nStructureChangeDemo\nTrust: Current Artifact,\nInvalidations\nCarries current for Section\nMetadata\nCarries invalidation for\nSection Review"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_7bcf353c_sectionmetadata: {
    label: "Section Metadata\nCarrier Output\nTarget: File\nPath: unit_root/_authoring/sec\ntion_metadata.json\nShape: Json Object\nRequirement: Required\nProduced by:\nStructureChangeDemo\nCurrent via Invalidation\nHandoff.Current Artifact"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_7bcf353c_blockedreviewhandoff: {
    label: "Blocked Review Handoff\nCarrier Output\nTarget: Turn Response\nShape: Comment\nRequirement: Required\nProduced by:\nBlockedSectionReviewDemo\nTrust: Invalidations"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_7bcf353c_rebuildhandoff: {
    label: "Rebuild Handoff\nCarrier Output\nTarget: Turn Response\nShape: Comment\nRequirement: Required\nProduced by:\nRebuildSectionReviewDemo\nTrust: Current Artifact\nCarries current for Section\nReview"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_7bcf353c_sectionreview: {
    label: "Section Review\nCarrier Output\nTarget: File\nPath: unit_root/_authoring/SEC\nTION_REVIEW.md\nShape: Markdown Document\nRequirement: Required\nProduced by:\nRebuildSectionReviewDemo\nInvalidated via Invalidation\nHandoff.Invalidations\nCurrent via Rebuild\nHandoff.Current Artifact"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }
}

