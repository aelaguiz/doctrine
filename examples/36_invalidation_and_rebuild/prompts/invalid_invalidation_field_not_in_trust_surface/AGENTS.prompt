# This file is intentionally invalid.
# The handoff has an invalidation field, but downstream readers are not told to trust it.

# The declarations below are just enough setup to isolate the one broken rule this file is testing.
output SectionReview: "Section Review"
    target: File
        path: "unit_root/_authoring/SECTION_REVIEW.md"
    shape: MarkdownDocument
    requirement: Required


# The declarations below are just enough setup to isolate the one broken rule this file is testing.
output CoordinationHandoff: "Coordination Handoff"
    target: TurnResponse
    shape: Comment
    requirement: Required

    # This field carries the name of whatever artifact is current right now.
    current_artifact: "Current Artifact"
        "Name the one artifact that is current now."

    # This field lists artifacts that used to be current but no longer are.
    invalidations: "Invalidations"
        "Name any artifacts that are no longer current."

    # Only the fields listed here are trustworthy readback for the next owner.
    trust_surface:
        current_artifact


# The declarations below are just enough setup to isolate the one broken rule this file is testing.
workflow InvalidStructureChange: "Structure Change"
    # This block holds the machine-checked rules for the turn.
    law:
        # This line says the branch carries no durable artifact forward.
        current none
        # This line explicitly says an artifact is no longer current downstream.
        # This invalidation uses a carrier field that downstream readers are not told to trust.
        invalidate SectionReview via CoordinationHandoff.invalidations


# The declarations below are just enough setup to isolate the one broken rule this file is testing.
agent InvalidInvalidationFieldNotInTrustSurface:
    role: "Trigger an invalidation carrier outside the trust surface."
    workflow: InvalidStructureChange
    outputs: "Outputs"
        CoordinationHandoff
