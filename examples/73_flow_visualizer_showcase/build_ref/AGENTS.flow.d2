direction: down

shared_inputs: {
  label: "Shared Inputs"
  direction: right
  style: {
    fill: "#F5F8FF"
    stroke: "#2F6FEB"
  }
  input_audienceguide: {
    label: "Audience Guide\nShared Input\nSource: File\nPath: project_root/_authoring/\nAUDIENCE_GUIDE.md\nShape: Markdown Document\nRequirement: Required\nUsed by: ProjectLead,\nResearchSpecialist,\nWritingSpecialist"
    shape: rectangle
    style: {
      fill: "#E8F1FF"
      stroke: "#2F6FEB"
    }
  }

  input_projectbrief: {
    label: "Project Brief\nShared Input\nSource: File\nPath: project_root/_authoring/\nPROJECT_BRIEF.md\nShape: Markdown Document\nRequirement: Required\nUsed by: ProjectLead,\nResearchSpecialist,\nWritingSpecialist"
    shape: rectangle
    style: {
      fill: "#E8F1FF"
      stroke: "#2F6FEB"
    }
  }
}

agent_handoffs: {
  label: "Agent Handoffs"
  direction: right
  style: {
    fill: "#FFF8EB"
    stroke: "#B54708"
  }
  agent_projectlead: {
    label: "ProjectLead\nAgent\nPlan the work, leave the\nexecution plan, and route the\nissue into research."
    shape: rectangle
    style: {
      fill: "#FFF7E6"
      stroke: "#B54708"
    }
  }

  agent_researchspecialist: {
    label: "ResearchSpecialist\nAgent\nTurn the shared brief into a\nreusable research packet."
    shape: rectangle
    style: {
      fill: "#FFF7E6"
      stroke: "#B54708"
    }
  }

  agent_writingspecialist: {
    label: "WritingSpecialist\nAgent\nTurn the research packet into\na launch-ready draft and\nreturn it to the lead."
    shape: rectangle
    style: {
      fill: "#FFF7E6"
      stroke: "#B54708"
    }
  }
}

shared_outputs_and_carriers: {
  label: "Shared Outputs And Carriers"
  direction: right
  style: {
    fill: "#F3FFF8"
    stroke: "#067647"
  }
  output_sharedhandoff: {
    label: "Shared Handoff\nShared Output / Carrier\nTarget: Turn Response\nShape: Comment\nRequirement: Required\nProduced by: ProjectLead,\nResearchSpecialist,\nWritingSpecialist\nTrust: Current Artifact, Use\nNow, Next Owner"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }
}

local_outputs: {
  label: "Local Outputs"
  direction: right
  style: {
    fill: "#F8FAFC"
    stroke: "#94A3B8"
  }
  output_executionplan: {
    label: "Execution Plan\nOutput\nTarget: File\nPath: project_root/_authoring/\nEXECUTION_PLAN.md\nShape: Markdown Document\nRequirement: Required\nProduced by: ProjectLead"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_launchdraft: {
    label: "Launch Draft\nOutput\nTarget: File\nPath: project_root/_authoring/\nLAUNCH_DRAFT.md\nShape: Markdown Document\nRequirement: Required\nProduced by: WritingSpecialist"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }

  output_researchpacket: {
    label: "Research Packet\nOutput\nTarget: File\nPath: project_root/_authoring/\nRESEARCH_PACKET.md\nShape: Markdown Document\nRequirement: Required\nProduced by:\nResearchSpecialist"
    shape: rectangle
    style: {
      fill: "#ECFDF3"
      stroke: "#067647"
    }
  }
}

agent_handoffs.agent_projectlead -> agent_handoffs.agent_researchspecialist: {
  label: "Start research with\nResearchSpecialist."
  style: {
    stroke: "#B54708"
  }
}

agent_handoffs.agent_researchspecialist -> agent_handoffs.agent_writingspecialist: {
  label: "Hand the research packet to\nWritingSpecialist."
  style: {
    stroke: "#B54708"
  }
}

agent_handoffs.agent_writingspecialist -> agent_handoffs.agent_projectlead: {
  label: "Return the draft to\nProjectLead."
  style: {
    stroke: "#B54708"
  }
}

shared_inputs.input_audienceguide -> agent_handoffs.agent_projectlead: {
  label: "consumes"
  style: {
    stroke: "#5B708B"
    stroke-dash: 4
  }
}

