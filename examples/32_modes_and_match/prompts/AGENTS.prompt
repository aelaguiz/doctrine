# This file shows how one typed mode selects one active branch.
# The `match` arms say what is current in each mode and what must stay true for that branch.

# Define a closed set of allowed values so later law can branch on names instead of free-form strings.
enum EditMode: "Edit Mode"
    manifest_title: "manifest-title"
    section_summary: "section-summary"


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input CurrentHandoff: "Current Handoff"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the host-provided handoff facts that say whether edit work is owed, which mode is active, and which preserve basis stays authoritative."


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input ApprovedPlan: "Approved Plan"
    source: File
        path: "unit_root/_authoring/APPROVED_PLAN.md"
    shape: MarkdownDocument
    requirement: Required


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input ApprovedStructure: "Approved Structure"
    source: File
        path: "unit_root/_authoring/APPROVED_STRUCTURE.md"
    shape: MarkdownDocument
    requirement: Required


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output CoordinationHandoff: "Coordination Handoff"
    target: TurnResponse
    shape: Comment
    requirement: Required

    # This field carries the name of whatever artifact is current right now.
    current_artifact: "Current Artifact"
        "Name the one artifact that is current now."

    # This field carries the one mode that was active for this pass.
    active_mode: "Active Mode"
        "Name the active mode for this pass."

    # Only the fields listed here are trustworthy readback for the next owner.
    trust_surface:
        current_artifact
        active_mode

    # This block says what a downstream owner should understand just from reading this output.
    standalone_read: "Standalone Read"
        "A downstream owner must be able to read this output alone and know which artifact is current now and which mode is active."


# Declare a reusable workflow. The title is human-facing, and the indented body holds prose plus checked law.
workflow ModeAwareEdit: "Mode-Aware Edit"
    "Edit in exactly one typed mode and carry that mode through the handoff."

    # This block holds the machine-checked rules for the turn.
    law:
        # This line turns the workflow on only when the condition is true.
        active when CurrentHandoff.owes_edit
        # This line binds one typed mode value that later rules can branch on.
        mode edit_mode = CurrentHandoff.active_mode as EditMode

        # This block splits the law by the chosen mode. Only one arm is active at a time.
        match edit_mode:
            EditMode.manifest_title:
                # This line says what artifact is current now and which output field must carry that fact forward.
                current artifact ApprovedPlan via CoordinationHandoff.current_artifact
                # This line states an invariant that has to hold in the active branch.
                must CurrentHandoff.preserve_basis == ApprovedPlan

            EditMode.section_summary:
                # This line says what artifact is current now and which output field must carry that fact forward.
                current artifact ApprovedStructure via CoordinationHandoff.current_artifact
                # This line states an invariant that has to hold in the active branch.
                must CurrentHandoff.preserve_basis == ApprovedStructure


# Declare a concrete agent that wires role text, workflow rules, and the needed inputs and outputs together.
agent ModeAwareEditDemo:
    role: "Edit in exactly one typed mode and carry that mode through the handoff."
    workflow: ModeAwareEdit
    inputs: "Inputs"
        CurrentHandoff
        ApprovedPlan
        ApprovedStructure
    outputs: "Outputs"
        CoordinationHandoff
