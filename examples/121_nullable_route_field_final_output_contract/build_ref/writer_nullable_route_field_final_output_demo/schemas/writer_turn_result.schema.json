{
  "title": "Writer Turn Result Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "next_route": {
      "title": "Next Route",
      "description": "Use null when the writer can finish without a handoff.",
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "revise_more",
        null
      ]
    },
    "kind": {
      "title": "Kind",
      "description": "Say whether this turn hands off or finishes.",
      "type": "string",
      "enum": [
        "handoff",
        "done"
      ]
    },
    "summary": {
      "title": "Summary",
      "description": "Short handoff or closeout summary.",
      "type": "string"
    }
  },
  "required": [
    "next_route",
    "kind",
    "summary"
  ]
}
