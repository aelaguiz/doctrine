input OutlineFile: "Outline File"
    source: File
        path: "unit_root/OUTLINE.md"
    shape: MarkdownDocument
    requirement: Required


schema EmptyGroupSchema: "Empty Group Schema"
    artifacts:
        outline_file: "Outline File"
            ref: OutlineFile

    groups:
        downstream_rebuild: "Downstream Rebuild"


agent EmptyGroupDemo:
    role: "Check {{EmptyGroupSchema:groups.downstream_rebuild.title}}."
    workflow: "Ship"
        "This should fail because schema groups may not be empty."
