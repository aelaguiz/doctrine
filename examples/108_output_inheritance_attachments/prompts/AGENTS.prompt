# This example shows inherited top-level output attachments.

render_profile CompactComment:
    properties -> sentence


output BaseReviewComment: "Base Review Comment"
    target: TurnResponse
    shape: Comment
    render_profile: CompactComment
    requirement: Required

    current_artifact: "Current Artifact"
        "Name the artifact that stays current."

    trust_surface:
        current_artifact

    standalone_read: "Standalone Read"
        "This comment should stand on its own."


output RoutedReviewComment[BaseReviewComment]: "Routed Review Comment"
    inherit target
    inherit shape
    inherit render_profile
    inherit requirement
    inherit current_artifact

    next_owner: "Next Owner"
        "Name the next owner when follow-up is needed."

    override standalone_read: "Standalone Read"
        "This comment should stand on its own."
        "It should also name the next owner when one exists."

    override trust_surface:
        current_artifact
        next_owner


agent OutputInheritanceAttachmentsDemo:
    role: "Keep inherited output attachments aligned."
    outputs: "Outputs"
        RoutedReviewComment
