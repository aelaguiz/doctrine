enum ProofRoute: "Proof Route"
    accept: "Accept"
    change: "Change"


output ProofResult: "Proof Result"
    target: TurnResponse
    shape: Comment
    requirement: Required
    route_choice: "Route Choice"


output RouteFromFinalReply: "Route From Final Reply"
    target: TurnResponse
    shape: Comment
    requirement: Required

    next_owner: route.next_owner.key


agent AcceptanceCritic:
    role: "Accept routed work."


agent ChangeEngineer:
    role: "Handle requested changes."


agent HandoffRouteFromFinalOutputDemo:
    role: "Read the selected handoff owner from an emitted output."
    outputs: "Outputs"
        ProofResult
        RouteFromFinalReply
    final_output: RouteFromFinalReply

    handoff_routing: "Handoff Routing"
        "Read the route choice from the emitted proof result."

        law:
            route_from ProofResult.route_choice as ProofRoute:
                ProofRoute.accept:
                    route "Send to AcceptanceCritic." -> AcceptanceCritic
                ProofRoute.change:
                    route "Send to ChangeEngineer." -> ChangeEngineer
