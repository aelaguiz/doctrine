# This file is a full walkthrough of the portable-truth pattern working end to end.
# It combines activation, mode selection, currentness, scope, comparison help, rewrite rules, invalidation, and rerouting in one place.

# Define a closed set of allowed values so later law can branch on names instead of free-form strings.
enum MetadataPolishMode: "Metadata Polish Mode"
    manifest_title: "manifest-title"
    section_summary: "section-summary"


# Define a closed set of allowed values so later law can branch on names instead of free-form strings.
enum RewriteRegime: "Rewrite Regime"
    carry_forward: "carry-forward"
    rewrite: "rewrite"


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input CurrentHandoff: "Current Handoff"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the host-provided handoff facts that say whether metadata polish is owed, which mode is active, which preserve basis remains authoritative, whether peer comparison is in play, whether this pass is a rewrite, and whether structure changed."


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input ApprovedPlan: "Approved Plan"
    source: File
        path: "unit_root/_authoring/APPROVED_PLAN.md"
    shape: MarkdownDocument
    requirement: Required


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input ApprovedStructure: "Approved Structure"
    source: File
        path: "unit_root/_authoring/APPROVED_STRUCTURE.md"
    shape: MarkdownDocument
    requirement: Required


# Declare an input the workflow can read on this turn. The nested fields explain where it comes from and what shape it has.
input AcceptedPeerSet: "Accepted Peer Set"
    source: File
        path: "catalog/accepted_peers.json"
    shape: JsonObject
    requirement: Advisory


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output PrimaryManifest: "Primary Manifest"
    target: File
        path: "unit_root/_authoring/primary_manifest.json"
    shape: JsonObject
    requirement: Required


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output SectionMetadata: "Section Metadata"
    target: File
        path: "unit_root/_authoring/section_metadata.json"
    shape: JsonObject
    requirement: Required


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output SectionReview: "Section Review"
    target: File
        path: "unit_root/_authoring/SECTION_REVIEW.md"
    shape: MarkdownDocument
    requirement: Required


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output BaseCoordinationHandoff: "Base Coordination Handoff"
    target: TurnResponse
    shape: Comment
    requirement: Required

    # This field carries the name of whatever artifact is current right now.
    current_artifact: "Current Artifact"
        "Name the one artifact that is current now."

    # This field carries the one mode that was active for this pass.
    active_mode: "Active Mode"
        "Name the one active mode for this pass."

    # This field tells the next owner which upstream source still controls the decisions.
    preserve_basis: "Preserve Basis"
        "Name the upstream declaration whose decisions remain authoritative."

    # This field lists read-only comparison help that informed the pass without becoming truth.
    comparison_basis: "Comparison Basis"
        "Name any comparison-only artifacts used in this pass."

    # Only the fields listed here are trustworthy readback for the next owner.
    trust_surface:
        current_artifact
        active_mode
        preserve_basis
        comparison_basis when CurrentHandoff.peer_comparison_used

    # This block says what a downstream owner should understand just from reading this output.
    standalone_read: "Standalone Read"
        "A downstream owner must be able to read this output alone and know what is current now, which mode is active, and why that preserve basis remains authoritative."


# Declare an output this turn can emit. The nested fields explain where it goes and what downstream readers learn from it.
output RewriteAwareCoordinationHandoff: "Rewrite-Aware Coordination Handoff"
    target: TurnResponse
    shape: Comment
    requirement: Required

    # This field carries the name of whatever artifact is current right now.
    current_artifact: "Current Artifact"
        "Name the one artifact that is current now."

    # This field carries the one mode that was active for this pass.
    active_mode: "Active Mode"
        "Name the one active mode for this pass."

    # This field tells the next owner which upstream source still controls the decisions.
    preserve_basis: "Preserve Basis"
        "Name the upstream declaration whose decisions remain authoritative."

    # This field lists read-only comparison help that informed the pass without becoming truth.
    comparison_basis: "Comparison Basis"
        "Name any comparison-only artifacts used in this pass."

    # This field lists old values that stop counting as evidence on rewrite passes.
    rewrite_exclusions: "Rewrite Evidence Exclusions"
        "Name any fields whose old values do not count as rewrite evidence."

    # This field lists artifacts that used to be current but no longer are.
    invalidations: "Invalidations"
        "Name any artifacts that are no longer current."

    # Only the fields listed here are trustworthy readback for the next owner.
    trust_surface:
        current_artifact
        active_mode
        preserve_basis
        comparison_basis when CurrentHandoff.peer_comparison_used
        rewrite_exclusions when CurrentHandoff.rewrite_regime == RewriteRegime.rewrite
        invalidations when CurrentHandoff.structure_changed

    # This block says what a downstream owner should understand just from reading this output.
    standalone_read: "Standalone Read"
        "A downstream owner must be able to read this output alone and know what is current now, which mode is active, why that preserve basis remains authoritative, what old wording does not count as rewrite evidence on rewrite passes, and what is no longer current when structure changed."


# Declare a concrete agent that wires role text, workflow rules, and the needed inputs and outputs together.
agent RoutingOwner:
    role: "Own explicit reroutes when the current specialist cannot continue."
    workflow: "Instructions"
        "Take back the same issue when metadata polish cannot continue safely."


# Declare a reusable workflow. The title is human-facing, and the indented body holds prose plus checked law.
workflow BaseMetadataPolish: "Metadata Polish"
    "Handle the last narrow wording pass after structure is already locked."

    # This block holds the machine-checked rules for the turn.
    law:
        # This named law section groups the rule that decides whether the workflow is active at all.
        activation:
            # This line turns the workflow on only when the condition is true.
            active when current_handoff.owes_metadata_polish

        # This named law section separates comparison help from truth-bearing evidence.
        evidence:
            # This line allows the input to help with comparison without letting it become current truth.
            support_only accepted_peer_set for comparison

        # This named law section gathers the conditions that stop or reroute the turn.
        stop_lines:
            # This block applies only when the condition is true inside the surrounding law context.
            when unclear(pass_mode, current_handoff.preserve_basis):
                # This line ends the turn with an explicit reason.
                stop "Mode or preserve basis is unclear."
                # This line sends the same work to a named owner with an explicit message.
                route "Route the same issue back to RoutingOwner." -> RoutingOwner


# Declare a reusable workflow. The title is human-facing, and the indented body holds prose plus checked law.
workflow RewriteAwareMetadataPolish[BaseMetadataPolish]: "Metadata Polish"
    # This block holds the machine-checked rules for the turn.
    law:
        # This line explicitly carries a named law section forward from the parent workflow.
        inherit activation
        mode_selection:
            # This line binds one typed mode value that later rules can branch on.
            mode pass_mode = MetadataPolishMode.section_summary as MetadataPolishMode

        currentness:
            # This line says what artifact is current now and which output field must carry that fact forward.
            current artifact section_metadata via coordination_handoff.current_artifact
            # This line states an invariant that has to hold in the active branch.
            must current_handoff.preserve_basis == approved_structure

        scope:
            # This line limits the edit authority to exactly the named fields.
            own only {section_metadata.name, section_metadata.description}
            # This line says everything outside the carve-out must stay exactly as it was.
            preserve exact section_metadata.* except {section_metadata.name, section_metadata.description}
            # This line keeps the upstream source authoritative for decisions while wording changes happen around it.
            preserve decisions approved_structure
            # This line names fields this branch is not allowed to modify.
            forbid {section_metadata.taxonomy, section_metadata.flags}

        # This line replaces or patches a named law section from the parent workflow.
        override evidence:
            # This line allows the input to help with comparison without letting it become current truth.
            support_only accepted_peer_set for comparison

            # This line says those old values stop counting as proof on rewrite passes.
            ignore {section_metadata.name, section_metadata.description} for rewrite_evidence when pass_mode == MetadataPolishMode.section_summary and current_handoff.rewrite_regime == RewriteRegime.rewrite

        # This line explicitly carries a named law section forward from the parent workflow.
        inherit stop_lines

        rewrite_stop_lines:
            # This block applies only when the condition is true inside the surrounding law context.
            when current_handoff.structure_changed:
                # This line explicitly says an artifact is no longer current downstream.
                invalidate SectionReview via coordination_handoff.invalidations
                # This line ends the turn with an explicit reason.
                stop "Structure moved; downstream review is no longer current."
                # This line sends the same work to a named owner with an explicit message.
                route "Route the same issue back to RoutingOwner for rebuild." -> RoutingOwner


# Declare a reusable workflow. The title is human-facing, and the indented body holds prose plus checked law.
workflow ManifestTitleMetadataPolish[BaseMetadataPolish]: "Metadata Polish"
    # This block holds the machine-checked rules for the turn.
    law:
        # This line explicitly carries a named law section forward from the parent workflow.
        inherit activation

        mode_selection:
            # This line binds one typed mode value that later rules can branch on.
            mode pass_mode = MetadataPolishMode.manifest_title as MetadataPolishMode

        currentness:
            # This line says what artifact is current now and which output field must carry that fact forward.
            current artifact primary_manifest via coordination_handoff.current_artifact
            # This line states an invariant that has to hold in the active branch.
            must current_handoff.preserve_basis == approved_plan

        scope:
            # This line limits the edit authority to exactly the named fields.
            own only primary_manifest.title
            # This line says everything outside the carve-out must stay exactly as it was.
            preserve exact primary_manifest.* except primary_manifest.title
            # This line keeps the upstream source authoritative for decisions while wording changes happen around it.
            preserve decisions approved_plan

        # This line explicitly carries a named law section forward from the parent workflow.
        inherit evidence
        # This line explicitly carries a named law section forward from the parent workflow.
        inherit stop_lines


# Declare a concrete agent that wires role text, workflow rules, and the needed inputs and outputs together.
agent MetadataPolishCapstoneDemo:
    role: "Handle the last narrow wording pass after structure is already locked."
    workflow: ManifestTitleMetadataPolish
    inputs: "Inputs"
        current_handoff: "Current Handoff Binding"
            CurrentHandoff

        approved_plan: "Approved Plan Binding"
            ApprovedPlan

        approved_structure: "Approved Structure Binding"
            ApprovedStructure

        accepted_peer_set: "Accepted Peer Set Binding"
            AcceptedPeerSet
    outputs: "Outputs"
        primary_manifest: "Primary Manifest Binding"
            PrimaryManifest

        coordination_handoff: "Coordination Handoff Binding"
            BaseCoordinationHandoff


# Declare a concrete agent that wires role text, workflow rules, and the needed inputs and outputs together.
agent RewriteAwareMetadataPolishCapstoneDemo:
    role: "Handle the last narrow wording pass after structure is already locked."
    workflow: RewriteAwareMetadataPolish
    inputs: "Inputs"
        current_handoff: "Current Handoff Binding"
            CurrentHandoff

        approved_plan: "Approved Plan Binding"
            ApprovedPlan

        approved_structure: "Approved Structure Binding"
            ApprovedStructure

        accepted_peer_set: "Accepted Peer Set Binding"
            AcceptedPeerSet
    outputs: "Outputs"
        section_metadata: "Section Metadata Binding"
            SectionMetadata

        coordination_handoff: "Coordination Handoff Binding"
            RewriteAwareCoordinationHandoff
