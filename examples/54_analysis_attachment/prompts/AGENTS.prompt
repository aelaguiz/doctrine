# This example introduces the concrete-agent `analysis:` attachment.
# The analysis declaration stays reusable and addressable, while the concrete
# agent keeps ordinary workflow ownership. It also proves that multi-basis
# analysis prose renders naturally instead of leaking symbolic set syntax.

enum RiskBand: "Risk Band"
    low: "Low"
    high: "High"

enum CompareRule: "Compare Rule"
    same_route: "Same Route"
    similar_burden: "Similar Burden"


analysis ReleaseAnalysis: "Release Analysis"
    stages: "Stages"
        prove "Release plan" from {CurrentPlan}
        classify "Risk band" as RiskBand
        compare "Coverage" against {CurrentPlan}
        defend "Recommendation" using {CurrentPlan}

analysis ReleaseComparisonAnalysis: "Release Comparison Analysis"
    stages: "Stages"
        derive "Release plan" from {CurrentPlan, PriorPlan}
        compare "Coverage" against {CurrentPlan, PriorPlan} using {CompareRule.same_route, CompareRule.similar_burden}
        defend "Recommendation" using {CurrentPlan, PriorPlan}


input CurrentPlan: "Current Plan"
    source: File
        path: "unit_root/CURRENT_PLAN.md"
    shape: MarkdownDocument
    requirement: Required

input PriorPlan: "Prior Plan"
    source: File
        path: "unit_root/PRIOR_PLAN.md"
    shape: MarkdownDocument
    requirement: Required


agent ReleaseAnalysisDemo:
    role: "Use {{ReleaseAnalysis:title}} and follow {{ReleaseAnalysis:stages.title}}."
    workflow: "Ship"
        "Use the attached analysis before you finalize the release plan."
    analysis: ReleaseAnalysis
    inputs: "Inputs"
        CurrentPlan

agent ReleaseComparisonAnalysisDemo:
    role: "Use {{ReleaseComparisonAnalysis:title}} and follow {{ReleaseComparisonAnalysis:stages.title}}."
    workflow: "Ship"
        "Use the attached comparison analysis before you finalize the release plan."
    analysis: ReleaseComparisonAnalysis
    inputs: "Inputs"
        CurrentPlan
        PriorPlan
