# This file is intentionally invalid.
# The workflow tries to preserve a mapping target that the language cannot find.

# The declarations below are just enough setup to isolate the one broken rule this file is testing.
input SlotMapping: "Slot Mapping"
    source: File
        path: "unit_root/_authoring/slot_mapping.json"
    shape: JsonObject
    requirement: Required


# The declarations below are just enough setup to isolate the one broken rule this file is testing.
output CoordinationHandoff: "Coordination Handoff"
    target: TurnResponse
    shape: Comment
    requirement: Required

    # This field carries the name of whatever artifact is current right now.
    current_artifact: "Current Artifact"
        "Name the one artifact that is current now."

    # Only the fields listed here are trustworthy readback for the next owner.
    trust_surface:
        current_artifact


# The declarations below are just enough setup to isolate the one broken rule this file is testing.
workflow InvalidPreserveMapping: "Preserve Mapping"
    # This block holds the machine-checked rules for the turn.
    law:
        # This line says what artifact is current now and which output field must carry that fact forward.
        current artifact SlotMapping via CoordinationHandoff.current_artifact
        # This line says source-to-target assignments must stay stable.
        # This preservation target does not resolve to a known declaration.
        preserve mapping MissingMapping


# The declarations below are just enough setup to isolate the one broken rule this file is testing.
agent InvalidUnknownMappingPreserveTarget:
    role: "Trigger an unknown mapping preserve target."
    workflow: InvalidPreserveMapping
    outputs: "Outputs"
        CoordinationHandoff
