skill package PluginMetadataPackage: "Plugin Metadata Package"
    metadata:
        name: "plugin-metadata-package"
        description: "Ship plugin metadata roots beside the main skill package."
        version: "1.0.0"
        license: "MIT"
    "The package keeps plugin metadata in `.codex-plugin/plugin.json`, `.app.json`, and `agents/openai.yaml`."
