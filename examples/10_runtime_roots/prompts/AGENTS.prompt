# This example sketches `runtime root` as a first-class reference-binding
# declaration.
# It only earns:
# - named runtime roots
# - root-relative file references using `root` + `path`
#
# It does not yet try to earn:
# - attached checkout bindings
# - symbolic runtime handles like `CURRENT_ISSUE`
# - owner-relative roots like `<owner_root>`

runtime root SectionRoot: "Section Root"
    kind: DirectoryPath

    bound_from: "Current Work Context"
        "The current work context names which section this turn is operating on."


runtime root LessonRoot: "Lesson Root"
    kind: DirectoryPath

    bound_from: "Current Work Context"
        "The current work context names which lesson this turn is operating on."


input SectionPlan: "Section Plan"
    source: File
        root: SectionRoot
        path: "_authoring/SECTION_PLAN.md"
    shape: MarkdownDocument
    requirement: Required
    "Read the current section plan from the bound section root."


input PreviousSummary: "Previous Summary"
    source: File
        root: SectionRoot
        path: "_authoring/PREVIOUS_SUMMARY.md"
    shape: MarkdownDocument
    requirement: Advisory
    "Use this only if continuity with earlier section work matters for the turn."


output SectionPlanOutput: "Section Plan Output"
    target: File
        root: SectionRoot
        path: "_authoring/SECTION_PLAN.md"
    shape: MarkdownDocument
    requirement: Required

    must_include: "Must Include"
        summary: "Summary"
            "Start with a short summary."

        planned_sections: "Planned Sections"
            "List the planned sections in order."

    support_files: "Support Files"
        section_flow_audit: "Section Flow Audit"
            root: SectionRoot
            path: "_authoring/SECTION_FLOW_AUDIT.md"
            when: "Section sizing or ordering constraints matter."

    owns: "Owns"
        "This output owns the current section plan at the bound section root."


output LessonReadbackOutput: "Lesson Readback Output"
    files: "Files"
        summary: "Lesson Summary"
            root: LessonRoot
            path: "_authoring/LESSON_SUMMARY.md"
            shape: MarkdownDocument

        validation: "Validation Notes"
            root: LessonRoot
            path: "_authoring/VALIDATION_NOTES.md"
            shape: MarkdownDocument

    requirement: Required

    must_include: "Must Include"
        lesson_summary: "Lesson Summary"
            "Summarize what changed in the lesson."

        validation_notes: "Validation Notes"
            "Name the checks or readbacks that still matter for the next turn."

    owns: "Owns"
        "This output owns the lesson readback files at the bound lesson root."


# Model 1: read files relative to a named runtime root.
agent SectionInputAgent:
    role: "Core job: read section files relative to the current section root."

    inputs: "Inputs"
        SectionPlan
        PreviousSummary

    your_job: "Your Job"
        "Read the required section plan from the bound section root."
        "Use the previous summary only if continuity matters for the current turn."
        "Fail if the required section plan is missing."


# Model 2: write one file and one support file relative to a named runtime root.
agent SectionOutputAgent:
    role: "Core job: write the section plan back to the current section root."

    outputs: "Outputs"
        SectionPlanOutput

    your_job: "Your Job"
        "Write the section plan to the bound section root."


# Model 3: write multiple files relative to a second named runtime root.
agent LessonOutputAgent:
    role: "Core job: write lesson readback files relative to the current lesson root."

    outputs: "Outputs"
        LessonReadbackOutput

    your_job: "Your Job"
        "Write the lesson summary and validation notes to the bound lesson root."
