{
  "title": "Repo Status Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": {
      "title": "Summary",
      "description": "Short natural-language status.",
      "type": "string"
    },
    "status": {
      "title": "Status",
      "description": "Current repo outcome.",
      "type": "string",
      "enum": [
        "ok",
        "action_required"
      ]
    },
    "next_step": {
      "title": "Next Step",
      "description": "Null only when no follow-up is needed.",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "summary",
    "status",
    "next_step"
  ]
}
