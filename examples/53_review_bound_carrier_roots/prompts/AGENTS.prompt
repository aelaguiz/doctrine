# This file shows that review currentness and carried review state compose with bound subject and carrier roots.

enum ReviewMode: "Review Mode"
    draft_rewrite: "draft-rewrite"


enum TriggerReason: "Trigger Reason"
    structure_gap: "structure-gap"


input DraftSpec: "Draft Spec"
    source: File
        path: "unit_root/DRAFT_SPEC.md"
    shape: MarkdownDocument
    requirement: Required
    "Use the current draft spec as the reviewed artifact."


input ReviewFacts: "Review Facts"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the host facts that say whether the draft still needs changes."


workflow BoundCarrierReviewContract: "Bound Carrier Review Contract"
    completeness: "Completeness"
        "Confirm the draft covers the required review basis."


agent ReviewLead:
    role: "Own accepted draft follow-up."
    workflow: "Follow Up"
        "Take the accepted draft to the next planning step."


agent DraftAuthor:
    role: "Repair rejected draft defects."
    workflow: "Revise"
        "Revise the same draft when review requests changes."


output BoundReviewComment: "Bound Review Comment"
    target: TurnResponse
    shape: Comment
    requirement: Required

    verdict: "Verdict"
        "Say whether the review accepted the draft or asked for changes."

    reviewed_artifact: "Reviewed Artifact"
        "Name the reviewed artifact this review judged."

    analysis_performed: "Analysis Performed"
        "Sum up the review work that led to the verdict."

    output_contents_that_matter: "Output Contents That Matter"
        "Summarize the parts of the draft the next owner must read first."

    next_owner: "Next Owner"
        "Name the next owner. Use {{ReviewLead}} when the draft is accepted and {{DraftAuthor}} when it is rejected."

    current_artifact: "Current Artifact"
        "Name the artifact that remains current after this review outcome."

    active_mode: "Active Mode" when present(active_mode):
        "Name the active review mode for the current artifact."

    trigger_reason: "Trigger Reason" when present(trigger_reason):
        "Name the trigger reason for the live artifact and mode."

    failure_detail: "Failure Detail" when verdict == ReviewVerdict.changes_requested:
        failing_gates: "Failing Gates"
            "Name the failing review gates in authored order."

    standalone_read: "Standalone Read"
        "This comment should stand on its own. The next owner should know what was reviewed, what verdict landed, what is still current, which mode and trigger reason are live, who owns next, and which parts of the draft still matter."

    trust_surface:
        current_artifact
        active_mode when present(active_mode)
        trigger_reason when present(trigger_reason)


review BoundCarrierReview: "Bound Carrier Review"
    subject: DraftSpec
    contract: BoundCarrierReviewContract
    comment_output: BoundReviewComment

    fields:
        verdict: verdict
        reviewed_artifact: reviewed_artifact
        analysis: analysis_performed
        readback: output_contents_that_matter
        failing_gates: failure_detail.failing_gates
        next_owner: next_owner
        active_mode: active_mode
        trigger_reason: trigger_reason

    contract_checks: "Contract Checks"
        reject "The draft still needs changes." when ReviewFacts.force_reject
        accept "The shared review contract passes." when contract.passes

    on_accept: "If Accepted"
        current artifact draft_spec via review_comment.current_artifact
        carry active_mode = ReviewMode.draft_rewrite
        carry trigger_reason = TriggerReason.structure_gap
        route "Accepted draft goes to ReviewLead." -> ReviewLead

    on_reject: "If Rejected"
        current artifact draft_spec via review_comment.current_artifact
        carry active_mode = ReviewMode.draft_rewrite
        carry trigger_reason = TriggerReason.structure_gap
        route "Rejected draft goes to DraftAuthor." -> DraftAuthor


agent BoundReviewCarrierDemo:
    role: "Keep review current truth and carried state aligned through named bindings."
    review: BoundCarrierReview
    inputs: "Inputs"
        draft_spec: "Draft Spec Binding"
            DraftSpec

        review_facts: "Review Facts Binding"
            ReviewFacts
    outputs: "Outputs"
        review_comment: "Review Comment Binding"
            BoundReviewComment
